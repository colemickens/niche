        {
            "name": "Run Tests",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}"
        },
        {
            "name": "Launch-Config-Init",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "env": {
                "NICHE_DEBUG": true,
                "AZURE_ACCOUNT": "azdev2020nov",
            },
            "args": [
                "config", "init", "-k", "azure", "-c", "newcache2",
                "--fingerprints", "8A94ED58A476A13AE0D6E85E9758078DE5308308,4774EB1BF21D57E93221CF0262556A61E301DC21,EAE0488FD59B66251E9004D1D7FA118E53E6D398",
