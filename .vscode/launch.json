    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch test package",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}"
        },
        {
            "name": "Launch-Build",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            //"env": {"NICHE_OVERWRITE": true},
            "args": [
                "build",
                "-u", "https://azdev2020nov.blob.core.windows.net/cach3",
                "--",
                "/home/cole/code/flake-impure", "--impure"
            ]
        },
        {
            "name": "Launch-Reconfigure",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "env": {},
            "args": [
                "reconfigure",
                "-u", "https://azdev2020nov.blob.core.windows.net/cach3",
                "-c", "./examples/azure-niche-config"
            ]
        }
    ]
}