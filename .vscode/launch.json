            "env": {
                //"NICHE_OVERWRITE": true,
                "NICHE_DEBUG": true
            },
            "args": [
                "build", "azdev2020nov.blob.core.windows.net/cache", "--",
                "/home/cole/code/nixpkgs-wayland#defaultPackage.x86_64-linux"
