            ]
        },
        {
            "name": "Launch-Config-Download",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "env": {
                "NICHE_DEBUG": true
            },
            "args": [
                "config", "download", "-f", "/tmp/something", "azdev2020nov.blob.core.windows.net/newcache2"
            ]
        },
        {
            "name": "Launch-Config-Upload",
            "type": "go",
