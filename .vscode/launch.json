    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch test package",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}"
        },
        {
            "name": "Launch-Build",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "env": {"NICHE_OVERWRITE": true},
            "args": [
                "build", "https://azdev2020nov.blob.core.windows.net/cache", "--",
                //"/home/cole/code/flake-impure", "--impure"
                "/home/cole/code/nixpkgs-wayland#defaultPackage.x86_64-linux"
            ]
        },
        {
            "name": "Launch-Reconfigure",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "env": {},
            "args": [
                "reconfigure",
                "-u", "https://azdev2020nov.blob.core.windows.net/cache",
                "-c", "./tests/azure.secret.json"
            ]
        }
    ]
}